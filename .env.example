# App
PORT=3000
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://enrichment_user:enrichment_pass@localhost:5432/enrichment_db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# BullMQ
QUEUE_CONCURRENCY=5

# Enrichment (mock — no real keys needed for assessment)
MOCK_ENRICHMENT_FAILURE_RATE=0.2
MOCK_ENRICHMENT_MIN_LATENCY_MS=200
MOCK_ENRICHMENT_MAX_LATENCY_MS=800
